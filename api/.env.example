# Application Configuration
NAME_APP=TheServerManagerAPI
NODE_ENV=development
PORT=3000

# Authentication
JWT_SECRET=your-secret-key-here
ADMIN_EMAIL=["admin@example.com"]

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Email Configuration (Nodemailer)
ADMIN_NODEMAILER_EMAIL_ADDRESS=admin@example.com
ADMIN_NODEMAILER_EMAIL_PASSWORD=your-app-password-here

# URLs
URL_THE404_WEB=https://localhost:3001/

# Porkbun DNS API Configuration
PORKBUN_API_KEY=your-porkbun-api-key
PORKBUN_SECRET_KEY=your-porkbun-secret-key

# App User Configuration
# Controls which system user's home directory the API manages.
# "nick" -> /home/nick/applications, "limited_user" -> /home/limited_user/applications
APP_USER=nick
#
# Staging directory for files that need sudo mv to system directories.
# Defaults to ${APP_USER_HOME}/project_resources/TheServerManager/staging
# Must be permitted in sudoers for: sudo mv <STAGING_DIR>/* /etc/systemd/system/
#                               and: sudo mv <STAGING_DIR>/* /etc/nginx/sites-available/
# The directory is auto-created on startup by verifyCheckDirectoryExists().
# STAGING_DIR=/home/limited_user/project_resources/TheServerManager/staging
#
# Systemctl CSV file: used to discover which services this server manages.
# The file must exist at ${APP_USER_HOME}/${APP_USER}-systemctl.csv
# Examples:
#   APP_USER=nick         -> /home/nick/nick-systemctl.csv
#   APP_USER=limited_user -> /home/limited_user/limited_user-systemctl.csv
# Create the file manually on each server before starting the API.

# File System Paths
PATH_PROJECT_RESOURCES=/path/to/project/resources
PATH_ETC_NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
PATH_TO_LOGS=/var/log/your-app

# Logging Configuration (Optional - Defaults Provided)
# LOG_MAX_SIZE=10485760  # Maximum log file size in bytes (default: 10MB)
# LOG_MAX_FILES=10       # Maximum number of log files to retain (default: 10)

# Child Process Logging (Only required if spawning child processes)
# NAME_CHILD_PROCESS=TheServerManagerAPI_Worker
# NAME_CHILD_PROCESS_BACKUP=TheServerManagerAPI_BackupService
# NAME_CHILD_PROCESS_CLEANUP=TheServerManagerAPI_CleanupService
