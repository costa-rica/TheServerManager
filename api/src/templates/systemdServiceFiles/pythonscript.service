[Unit]
Description={{PROJECT_NAME}} Services Job

[Service]
Type=oneshot
User={{USER}}
Group={{GROUP}}
WorkingDirectory={{USER_HOME}}/applications/{{PROJECT_NAME}}{{SUBPROJECT_PATH}}
Environment="PATH={{USER_HOME}}/environments/{{PYTHON_ENV_NAME}}/bin"
EnvironmentFile={{USER_HOME}}/applications/{{PROJECT_NAME}}{{SUBPROJECT_PATH}}/.env
ExecStart={{USER_HOME}}/environments/{{PYTHON_ENV_NAME}}/bin/python src/main.py
