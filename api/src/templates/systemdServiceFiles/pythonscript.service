[Unit]
Description={{PROJECT_NAME}} Services Job
StartLimitIntervalSec=1d
StartLimitBurst=5

[Service]
Type=oneshot
User={{USER}}
Group={{GROUP}}
WorkingDirectory={{USER_HOME}}/applications/{{PROJECT_NAME}}
Environment="PATH={{USER_HOME}}/environments/{{PYTHON_ENV_NAME}}/bin"
EnvironmentFile={{USER_HOME}}/applications/{{PROJECT_NAME}}/.env
ExecStart={{USER_HOME}}/environments/{{PYTHON_ENV_NAME}}/bin/python src/main.py
Restart=on-failure
RestartSec=10
